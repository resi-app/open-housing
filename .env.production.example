# OpenResiApp — Production environment variables
# Copy to .env on your server: cp .env.production.example .env
# Then fill in real values

# App
APP_NAME="Bytové spoločenstvo Hlavná 12"
APP_URL=https://yourdomain.sk
APP_DOMAIN=yourdomain.sk

# Database — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Auth — generate with: openssl rand -base64 64
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_SECRET_HERE
NEXTAUTH_URL=https://yourdomain.sk

# Language (sk or en)
LANGUAGE=sk

# Email (optional — for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.sk

# Voting — require email confirmation for votes (true/false)
REQUIRE_VOTE_EMAIL=false

# Remote backup (optional — pick ONE provider, leave others empty)
# Local backup always runs regardless of remote config.
BACKUP_DIR=/backups/resiapp

# --- Option A: Hetzner Storage Box (BorgBackup) ---
# Setup: ./scripts/backup-hetzner-setup.sh
BORG_REPO=                    # ssh://u123456@u123456.your-storagebox.de:23/./resiapp
BORG_PASSPHRASE=              # generate with: openssl rand -base64 32
BORG_SSH_KEY=~/.ssh/id_ed25519_borg

# --- Option B: AWS S3 (Restic) ---
# Setup: ./scripts/backup-aws-setup.sh
# RESTIC_REPOSITORY=            # s3:s3.eu-central-1.amazonaws.com/my-bucket/resiapp
# RESTIC_PASSWORD=              # generate with: openssl rand -base64 32
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Option C: Azure Blob Storage (Restic) ---
# Setup: ./scripts/backup-azure-setup.sh
# RESTIC_REPOSITORY=            # azure:resiapp-backups:/resiapp
# RESTIC_PASSWORD=              # generate with: openssl rand -base64 32
# AZURE_ACCOUNT_NAME=
# AZURE_ACCOUNT_KEY=

# CRITICAL: Store BORG_PASSPHRASE / RESTIC_PASSWORD in a separate safe location.
# If you lose it, encrypted backups are UNRECOVERABLE.
